{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",
		"strict": false,
		"jsx": "preserve",
		"sourceMap": true,
		"esModuleInterop": true,
		"lib": ["esnext", "dom"],
		"types": ["./types"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.d.ts",
		"**/*.vue"
	],
	"exclude": [
		"node_modules",
		"unpackage"
	]
}
